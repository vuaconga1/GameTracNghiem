generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  passwordHash     String
  displayName      String
  role             String            @default("student")
  createdAt        DateTime          @default(now())
  archivedAt       DateTime?
  progress         GameProgress[]
  scoreLogs        ScoreLog[]
  experience       PlayerExperience?
  experienceGrants ExperienceGrant[]
}

model ClassLevel {
  id         String    @id @default(cuid())
  levelName  String    @unique
  active     Boolean   @default(true)
  archivedAt DateTime?
}

model Ebook {
  id           String    @id @default(cuid())
  title        String
  originalName String
  storageKey   String
  pageCount    Int?
  active       Boolean   @default(true)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([archivedAt])
}

model Course {
  id                 String             @id @default(cuid())
  name               String
  levelName          String
  active             Boolean            @default(true)
  archivedAt         DateTime?
  /**
   * Legacy: game keys visible to students. Empty = all catalog games enabled.
   * Prefer gameSkills + enabledSkills; kept in sync on admin write.
   */
  enabledGames       String[]           @default([])
  /**
   * Per-unit map of gameKey → skill id (or null/omit = hidden).
   * See lib/skillCatalog.ts and docs/superpowers/specs/2026-07-23-unit-skill-cards-design.md
   */
  gameSkills         Json?
  /**
   * Skill ids shown as student cards. Empty = all four skills enabled.
   */
  enabledSkills      String[]           @default([])
  /**
   * References Ebook.id when set.
   */
  ebookFileId        String?
  ebookPageStart     Int?
  ebookPageEnd       Int?
  backgroundImageUrl String?
  backgroundImageKey String?
  questions          Question[]
  gameLessons        CourseGameLesson[]
  skillLessons       CourseSkillLesson[]

  @@index([levelName])
  @@index([name])
  @@index([archivedAt])
  @@index([ebookFileId])
}

model CourseGameLesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  gameKey   String
  pageStart Int
  pageEnd   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, gameKey])
  @@index([courseId])
}

/**
 * Per-skill page range within the unit's ebook (same PDF file).
 * skillId: listening | reading | speaking | writing | vocabulary
 */
model CourseSkillLesson {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skillId   String
  pageStart Int
  pageEnd   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, skillId])
  @@index([courseId])
}

model Question {
  id         String    @id @default(cuid())
  courseId   String
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  game       String
  level      String?
  payload    Json
  active     Boolean   @default(true)
  archivedAt DateTime?
  sortOrder  Int       @default(0)
  externalId String?

  @@index([courseId, game, active])
  @@index([archivedAt])
}

model GameProgress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseKey     String
  game          String
  statuses      Json
  playSessionId String?
  updatedAt     DateTime @updatedAt

  @@unique([userId, courseKey, game])
}

model ScoreLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        String
  game          String
  questionIndex Int
  isCorrect     Boolean
  elapsedMs     Int
  points        Int
  playSessionId String?
  answeredAt    DateTime @default(now())

  @@index([userId, course])
  @@index([answeredAt])
  @@index([game])
  @@index([userId, course, game, playSessionId])
}

model PlayerExperience {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalExp  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExperienceGrant {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  playSessionId       String
  course              String
  game                String
  exp                 Int
  answeredCount       Int
  correctCount        Int
  averageCorrectSpeed Float
  createdAt           DateTime @default(now())

  @@unique([userId, playSessionId])
  @@index([userId, createdAt])
  @@index([playSessionId])
}
