generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String         @id @default(cuid())
  username     String         @unique
  passwordHash String
  displayName  String
  role         String         @default("student")
  createdAt    DateTime       @default(now())
  archivedAt   DateTime?
  progress     GameProgress[]
  scoreLogs    ScoreLog[]
}

model ClassLevel {
  id         String    @id @default(cuid())
  levelName  String    @unique
  active     Boolean   @default(true)
  archivedAt DateTime?
}

model Ebook {
  id           String    @id @default(cuid())
  title        String
  originalName String
  storageKey   String
  pageCount    Int?
  active       Boolean   @default(true)
  archivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([archivedAt])
}

model Course {
  id             String     @id @default(cuid())
  name           String
  levelName      String
  active         Boolean    @default(true)
  archivedAt     DateTime?
  /** Game keys visible to students. Empty = all catalog games enabled. */
  enabledGames   String[]   @default([])
  /** References Ebook.id when set. */
  ebookFileId    String?
  ebookPageStart Int?
  ebookPageEnd   Int?
  questions      Question[]

  @@index([levelName])
  @@index([name])
  @@index([archivedAt])
  @@index([ebookFileId])
}

model Question {
  id         String    @id @default(cuid())
  courseId   String
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  game       String
  level      String?
  payload    Json
  active     Boolean   @default(true)
  archivedAt DateTime?
  sortOrder  Int       @default(0)
  externalId String?

  @@index([courseId, game, active])
  @@index([archivedAt])
}

model GameProgress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseKey     String
  game          String
  statuses      Json
  playSessionId String?
  updatedAt     DateTime @updatedAt

  @@unique([userId, courseKey, game])
}

model ScoreLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course        String
  game          String
  questionIndex Int
  isCorrect     Boolean
  elapsedMs     Int
  points        Int
  playSessionId String?
  answeredAt    DateTime @default(now())

  @@index([userId, course])
  @@index([answeredAt])
  @@index([game])
  @@index([userId, course, game, playSessionId])
}
