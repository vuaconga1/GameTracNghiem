# =============================================================================
# Hai file env chạy song song
# =============================================================================
# .env          → Neon (cloud)
# .env.local    → PostgreSQL local — ghi đè khi npm run dev:local
#
# npm run dev              → Neon (.env)
# npm run dev:local        → Postgres local (.env.local)
# npm run db:deploy        → migrate Neon
# npm run db:deploy:local  → migrate local
# =============================================================================

# --- Neon (cloud) — file .env ---
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-XXXX-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-XXXX.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Local Postgres — file .env.local ---
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/wewin_game"
# DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/wewin_game"

SESSION_SECRET="replace-with-long-random-string-at-least-32-chars"

# Parent Portal SSO (must match Apps Script CFG.GAME_SSO_SECRET)
PORTAL_SSO_SECRET="replace-with-shared-portal-sso-secret-32+"

# Groq Whisper (pronunciation game). Missing/429 → client falls back to Web Speech.
# https://console.groq.com/keys
GROQ_API_KEY=""

# OpenAI Realtime (AI Speaking). Key stays server-side only.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-mini"

# Google Drive — Speaking recordings (service account)
# Folder: https://drive.google.com/drive/folders/1_r_lSba4dHyngN0boNm70kKEWxTaKa7G
GOOGLE_DRIVE_SPEAKING_FOLDER_ID="1_r_lSba4dHyngN0boNm70kKEWxTaKa7G"
# Paste the full service-account JSON as a single line (escape newlines as \n in private_key).
# Share that folder with the service account email as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON=""
# Optional alternative for Vercel: base64 of the JSON file
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=""

# Vercel Blob (bắt buộc trên Vercel để lưu/đọc PDF ebook — disk local không tồn tại trên serverless)
# Tạo tại: Vercel → Project → Storage → Blob → tạo store → copy token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
